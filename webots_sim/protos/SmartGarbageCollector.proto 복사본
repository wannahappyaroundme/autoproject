#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/vehicles/protos/abstract/GenericTireAppearance.proto"

PROTO SmartGarbageCollector [
  field SFVec3f    translation 0 0 0.05
  field SFRotation rotation    0 0 1 0
  field SFString   name        "Smart_Garbage_Collector"
  field SFString   controller  "Robot_controller"
]
{
  Robot {
    translation IS translation
    rotation IS rotation
    name IS name
    controller IS controller
    
    children [
      Hinge2Joint {
        jointParameters HingeJointParameters {
          axis 0 0 1
          anchor 0.11 0.1485 0
        }
        jointParameters2 JointParameters { axis 0 1 0 }
        device [ RotationalMotor { name "steer_fl" } ]
        endPoint Solid {
          translation 0.11 0.1485 0
          contactMaterial "rubber"
          children [
            Transform {
              rotation 0 0 1 -1.5707996938995747
              scale 0.001 0.001 0.001
              children [
                Shape {
                  appearance GenericTireAppearance {}
                  geometry Mesh { url [ "Meshes/모듈 - 휠 2.stl" ] }
                }
              ]
            }
          ]
          name "wheel_fl"
          boundingObject Pose {
            rotation 1 0 0 1.5708
            children [ Cylinder { height 0.03 radius 0.04 } ]
          }
          physics Physics {}
        }
      }
      Hinge2Joint {
        jointParameters HingeJointParameters {
          axis 0 0 1
          anchor 0.11 -0.1485 0
        }
        jointParameters2 JointParameters { axis 0 1 0 }
        device [ RotationalMotor { name "steer_fr" } ]
        endPoint Solid {
          translation 0.11 -0.1485 0
          contactMaterial "rubber"
          children [
            Transform {
              rotation 0 0 1 -1.5707996938995747
              scale 0.001 0.001 0.001
              children [
                Shape {
                  appearance GenericTireAppearance {}
                  geometry Mesh { url [ "Meshes/모듈 - 휠 2.stl" ] }
                }
              ]
            }
          ]
          name "wheel_fr"
          boundingObject Pose {
            rotation 1 0 0 1.5708
            children [ Cylinder { height 0.03 radius 0.04 } ]
          }
          physics Physics {}
        }
      }
      HingeJoint {
        jointParameters HingeJointParameters {
          axis 0 1 0
          anchor -0.11 0.1485 0
        }
        device [ RotationalMotor { name "drive_bl" } ]
        endPoint Solid {
          translation -0.11 0.1485 0
          contactMaterial "rubber"
          children [
            Transform {
              rotation 0 0 1 -1.5707996938995747
              scale 0.001 0.001 0.001
              children [
                Shape {
                  appearance GenericTireAppearance {}
                  geometry Mesh { url [ "Meshes/모듈 - 휠 2.stl" ] }
                }
              ]
            }
          ]
          name "wheel_bl"
          boundingObject Pose {
            rotation 1 0 0 1.5708
            children [ Cylinder { height 0.03 radius 0.04 } ]
          }
          physics Physics {}
        }
      }
      HingeJoint {
        jointParameters HingeJointParameters {
          axis 0 1 0
          anchor -0.11 -0.1485 0
        }
        device [ RotationalMotor { name "drive_br" } ]
        endPoint Solid {
          translation -0.11 -0.1485 0
          contactMaterial "rubber"
          children [
            Transform {
              rotation 0 0 1 -1.5707996938995747
              scale 0.001 0.001 0.001
              children [
                Shape {
                  appearance GenericTireAppearance {}
                  geometry Mesh { url [ "Meshes/모듈 - 휠 2.stl" ] }
                }
              ]
            }
          ]
          name "wheel_br"
          boundingObject Pose {
            rotation 1 0 0 1.5708
            children [ Cylinder { height 0.03 radius 0.04 } ]
          }
          physics Physics {}
        }
      }
      DEF BODY_VISUAL Transform {
        scale 0.001 0.001 0.001
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0.2 0.2 0.2
              metalness 0
            }
            geometry Mesh { url [ "Meshes/모듈 - 바디.stl" ] }
          }
        ]
      }    
    # 📷 카메라 B: RealSense (SLAM용)
    Camera {
      translation 0.15 0 0.2  # 로봇 앞쪽 상단
      name "realsense_color"
      width 640 height 480
    }
    RangeFinder {
      translation 0.15 0 0.2
      name "realsense_depth"
      width 640 height 480
    }
    
    # 📷 카메라 A: 웹캠 (QR 인식용)
    Camera {
      translation 0.15 0 0.1  # 로봇 앞쪽 하단
      name "webcam_color"
    }

    # 📏 초음파 센서 5개 (이름을 경석님 코드와 똑같이!)
    DistanceSensor { translation 0.15 0.1 0.05 name "us_front_left" lookupTable [0 1000 0, 1 0 0] }
    DistanceSensor { translation 0.15 -0.1 0.05 name "us_front_right" lookupTable [0 1000 0, 1 0 0] }
    # ... (나머지 side_left, side_right, rear도 같은 방식으로 추가)
    
    # 🧭 관성 센서 (IMU)
    InertialUnit { name "imu" }
    Gyro { name "gyro" }
    Accelerometer { name "accelerometer" }
    ]
    
    boundingObject Group {
      children [
        Pose { translation 0.0375 -0.11 0.015 children [ Box { size 0.175 0.03 0.03 } ] }
        Pose { translation 0.0375 0.11 0.015 children [ Box { size 0.175 0.03 0.03 } ] }
        Pose { translation -0.0875 0 0.13 children [ Box { size 0.075 0.25 0.26 } ] }
      ]
    }
    physics Physics {
      mass 1.0
      centerOfMass [ 0.05 0 0.101 ]
    }
  }
}