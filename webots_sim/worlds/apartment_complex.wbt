# ============================================================

# 집하장 바닥 마커 (노란색 원)
Solid {
  translation 15 0.005 20
  rotation 1 0 0 -1.5708
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1.0 0.85 0.0
        roughness 0.4
        metalness 0.0
        emissiveColor 0.3 0.25 0.0
      }
      geometry Cylinder {
        height 0.01
        radius 1.2
      }
    }
  ]
  name "collection_point_marker"
}

# 집하장 콘 (가시성 향상 — 키 큰 원뿔)
