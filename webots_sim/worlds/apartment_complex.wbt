#VRML_SIM R2023b utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "../protos/WasteRobot.proto"

# ============================================================
# 아파트 단지 음식물쓰레기통 수거 로봇 시뮬레이션 월드
# ============================================================
#
# 좌표 체계:
#   - 월드 크기: 60m x 40m (1 grid cell = 1 meter)
#   - 맵 X -> Webots X, 맵 Y -> Webots Z, 높이 -> Webots Y
#   - 원점(0,0,0)은 맵 좌상단에 대응
#   - 건물 중심 좌표: cx = (x1+x2)/2, cz = (y1+y2)/2
#   - 건물 크기: sx = (x2-x1+1), sz = (y2-y1+1)
#
# 맵 레이아웃 (mock-data.ts 기준):
#   Row 1: (3,3)-(6,7), (9,3)-(12,7), (3,10)-(6,14), (9,10)-(12,14)
#   Row 2: (18,3)-(21,7), (24,3)-(27,7), (18,10)-(21,14), (24,10)-(27,14)
#   Row 3: (3,22)-(6,26), (9,22)-(12,26), (3,28)-(6,32), (9,28)-(12,32)
#   Row 4: (18,22)-(21,26), (24,22)-(27,26), (18,28)-(21,32), (24,28)-(27,32)
#   Row 5: (3,34)-(6,38), (9,34)-(12,38), (18,34)-(21,38), (24,34)-(27,38)
#   Playground: (38,10)-(42,13), Office: (48,3)-(53,6)
#   Parking A: (38,25)-(45,28), Parking B: (48,25)-(55,28)
#   Guard: (33,1)-(34,2)
#   Collection Point: (15,20)
# ============================================================

WorldInfo {
  title "Apartment Complex - Waste Collection Robot"
  basicTimeStep 16
  FPS 60
  gravity 0 -9.81 0
  contactProperties [
    ContactProperties {
      material1 "rubber"
      material2 "concrete"
      coulombFriction [1.0]
      bounce 0.0
    }
  ]
}

Viewpoint {
  orientation -0.9999 0.0 0.0 1.2
  position 30 55 20
  follow "waste_robot"
  followType "None"
}

TexturedBackground {
  texture "noon_cloudy_countryside"
}

TexturedBackgroundLight {
  luminosity 1.2
}

# --- 태양광 (DirectionalLight) ---
DirectionalLight {
  ambientIntensity 0.5
  direction -0.3 -1 -0.5
  intensity 0.8
  castShadows TRUE
}

# --- 보조 조명 (반대편에서 그림자 완화) ---
DirectionalLight {
  ambientIntensity 0.3
  direction 0.4 -0.8 0.3
  intensity 0.4
  castShadows FALSE
}

# ============================================================
# 바닥 (아파트 단지 전체 영역: 60m x 40m)
# ============================================================
RectangleArena {
  translation 30 0 20
  floorSize 60 40
  floorTileSize 2 2
  floorAppearance PBRAppearance {
    baseColor 0.75 0.75 0.72
    roughness 0.8
    metalness 0.0
  }
  wallThickness 0.3
  wallHeight 2.0
  wallAppearance PBRAppearance {
    baseColor 0.6 0.6 0.6
    roughness 0.7
  }
}

