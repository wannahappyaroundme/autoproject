# ============================================================
# 쓰레기통 16개 (QR 코드 부착 녹색 실린더)
# ============================================================
# BIN_POSITIONS from mock-data.ts:
#   [7,8],[13,8],[22,8],[28,8],[7,20],[13,20],[22,20],[28,20],
#   [7,32],[13,32],[22,32],[28,32],[40,15],[45,15],[40,30],[50,30]

# --- 101동-01: 맵(7,8) -> Webots(7, 0, 8) ---
Solid {
  translation 7 0.2 8
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.5 0.2
        roughness 0.7
        metalness 0.1
      }
      geometry Cylinder {
        height 0.4
        radius 0.12
      }
    }
    # QR 코드 면 (흰색 사각형)
    Pose {
      translation 0 0.05 0.121
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 1.0 1.0 1.0
            roughness 0.3
          }
          geometry Box {
            size 0.1 0.1 0.001
          }
        }
      ]
    }
  ]
  name "bin_101-01"
  boundingObject Cylinder {
    height 0.4
    radius 0.12
  }
  physics Physics {
    mass 0.5
  }
}

# --- 101동-02: 맵(13,8) -> Webots(13, 0, 8) ---
Solid {
  translation 13 0.2 8
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.5 0.2
        roughness 0.7
        metalness 0.1
      }
      geometry Cylinder {
        height 0.4
        radius 0.12
      }
    }
    Pose {
      translation 0 0.05 0.121
      children [
        Shape {
