# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 동적 장애물 (웹 시뮬레이션과 동기화)
# Obstacle_sync_controller가 백엔드에서 위치를 읽어 이동
# 크기: 1셀=0.5m 기준, 웹 그리드와 동일
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 보행자 1 (1×1셀 = 0.5m×0.5m, 높이 1.5m)
DEF OBS_1 Robot {
  translation -3.5 2.5 0.75
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.9 0.7 0.5 roughness 0.8 }
      geometry Cylinder { height 1.5 radius 0.15 }
    }
    # 머리
    Transform {
      translation 0 0 0.85
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.9 0.75 0.6 roughness 0.7 }
          geometry Sphere { radius 0.12 }
        }
      ]
    }
  ]
  name "obs_1"
  boundingObject Cylinder { height 1.5 radius 0.15 }
  physics Physics { density -1 mass 2 }
  controller "Obstacle_sync_controller"
  controllerArgs ["1"]
  supervisor TRUE
}

# 보행자 2 (1×1셀)
DEF OBS_2 Robot {
  translation 2.5 1.5 0.75
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.5 0.6 0.8 roughness 0.8 }
      geometry Cylinder { height 1.5 radius 0.15 }
    }
    Transform {
      translation 0 0 0.85
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.8 0.7 0.6 roughness 0.7 }
          geometry Sphere { radius 0.12 }
        }
      ]
    }
  ]
  name "obs_2"
  boundingObject Cylinder { height 1.5 radius 0.15 }
  physics Physics { density -1 mass 2 }
  controller "Obstacle_sync_controller"
  controllerArgs ["2"]
  supervisor TRUE
}

# 승용차 (3×2셀 = 1.5m×1.0m, 높이 0.6m)
DEF OBS_3 Robot {
  translation -4.0 -4.0 0.3
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.3 0.3 0.7 roughness 0.5 metalness 0.3 }
      geometry Box { size 1.5 1.0 0.6 }
    }
    # 창문
    Transform {
      translation 0 0 0.2
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.7 0.85 0.95 roughness 0.1 metalness 0.5 }
          geometry Box { size 1.0 0.9 0.25 }
        }
      ]
    }
  ]
  name "obs_3"
  boundingObject Box { size 1.5 1.0 0.6 }
  physics Physics { density -1 mass 10 }
  controller "Obstacle_sync_controller"
  controllerArgs ["3"]
  supervisor TRUE
}

# 강아지 (1×1셀 = 0.5m×0.3m, 높이 0.3m)
DEF OBS_4 Robot {
  translation 2.5 2.5 0.15
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.6 0.4 0.2 roughness 0.9 }
      geometry Box { size 0.4 0.25 0.3 }
    }
  ]
  name "obs_4"
  boundingObject Box { size 0.4 0.25 0.3 }
  physics Physics { density -1 mass 3 }
  controller "Obstacle_sync_controller"
  controllerArgs ["4"]
  supervisor TRUE
}

# 손수레 (2×1셀 = 1.0m×0.5m, 높이 0.4m)
DEF OBS_5 Robot {
  translation -3.0 -4.0 0.2
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.5 0.5 0.55 roughness 0.7 }
      geometry Box { size 1.0 0.5 0.4 }
    }
  ]
  name "obs_5"
  boundingObject Box { size 1.0 0.5 0.4 }
  physics Physics { density -1 mass 5 }
  controller "Obstacle_sync_controller"
  controllerArgs ["5"]
  supervisor TRUE
}

# 자전거 (2×1셀 = 1.0m×0.3m, 높이 0.7m)
DEF OBS_6 Robot {
  translation 5.0 2.5 0.35
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.8 0.2 0.2 roughness 0.6 metalness 0.2 }
      geometry Box { size 1.0 0.3 0.7 }
    }
  ]
  name "obs_6"
  boundingObject Box { size 1.0 0.3 0.7 }
  physics Physics { density -1 mass 4 }
  controller "Obstacle_sync_controller"
  controllerArgs ["6"]
