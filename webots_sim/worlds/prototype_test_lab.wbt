# controller를 Prototype_controller로 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 로봇-A (CS-1에서 시작, grid: 2,2)
SmartGarbageCollector {
  translation -6.5 4.0 0.05
  name "Robot_A"
  controller "Prototype_controller"
  bodyColor 0.9 0.2 0.2
}

# 로봇-B (CS-2에서 시작, grid: 27,2)
