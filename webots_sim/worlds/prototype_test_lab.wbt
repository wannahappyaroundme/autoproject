#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "../protos/SmartGarbageCollector.proto"

WorldInfo {
  info [
    "시제품 테스트 랩"
    "30×20 그리드 (1셀=0.5m) → 15m × 10m 공간"
    "로봇 2대, 쓰레기통 4개"
  ]
  title "Prototype Test Lab"
  basicTimeStep 32
}
Viewpoint {
  orientation -0.5 0.5 0.7071 3.14159
  position 0 0 18
}
TexturedBackground {
}
TexturedBackgroundLight {
}

# ── 바닥: 15m × 10m (30×20 × 0.5m/cell) ──
RectangleArena {
  floorSize 15 10
  floorTileSize 0.5 0.5
  wallHeight 0.3
  wallThickness 0.05
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 장애물 (웹 mock-data-prototype.ts와 동일 배치)
# 그리드→월드 변환: wx = (gx - 15) * 0.5, wy = (10 - gy) * 0.5
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 중앙 테이블 (grid: 12,8 ~ 16,11 → 중심 14,9.5)
DEF TABLE Solid {
  translation -0.5 0.25 0.35
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.6 0.4 0.2
        roughness 0.8
      }
      geometry Box {
        size 2.5 2.0 0.7
      }
    }
  ]
  name "table"
  boundingObject Box {
    size 2.5 2.0 0.7
  }
}

# 왼쪽 선반 (grid: 3,8 ~ 4,12 → 중심 3.5,10)
DEF SHELF Solid {
  translation -5.75 0 0.4
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.5 0.5 0.5
        roughness 0.6
      }
      geometry Box {
        size 1.0 2.5 0.8
      }
    }
  ]
  name "shelf"
  boundingObject Box {
    size 1.0 2.5 0.8
  }
}

# 오른쪽 캐비닛 (grid: 25,11 ~ 27,14 → 중심 26,12.5)
DEF CABINET Solid {
  translation 5.5 -1.25 0.4
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.4
        roughness 0.5
      }
      geometry Box {
        size 1.5 2.0 0.8
      }
    }
  ]
  name "cabinet"
  boundingObject Box {
    size 1.5 2.0 0.8
  }
}

# 수거함 표시 (grid: 15,2 → collection point)
DEF COLLECTION_POINT Solid {
  translation 0 4.0 0.15
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.6 0.1
        roughness 0.3
      }
      geometry Cylinder {
        height 0.3
        radius 0.3
      }
    }
  ]
  name "collection_point"
}

