# 주차장 (grid: 29,21 ~ 35,25)
# center: gx=32, gy=23 → wx=6.0, wy=-4.0
# size: 3.5, 2.5, height=0.1 (바닥 표시)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DEF PARKING Solid {
  translation 6.0 -4.0 0.05
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
        roughness 0.8
        metalness 0
      }
      geometry Box {
        size 3.5 2.5 0.1
      }
    }
  ]
  name "주차장"
  boundingObject Box {
    size 3.5 2.5 0.1
  }
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 경비실 (grid: 19,28 ~ 21,28)
# center: gx=20, gy=28 → wx=0, wy=-6.5
# size: 1.5, 0.5, height=1.0
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DEF GUARD Solid {
  translation 0 -6.5 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.7 0.5 0.3
        roughness 0.7
        metalness 0
      }
      geometry Box {
        size 1.5 0.5 1.0
      }
    }
  ]
  name "경비실"
  boundingObject Box {
    size 1.5 0.5 1.0
  }
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 수거함 (Collection Point)
# grid: 20,27 → wx=0, wy=-6.0
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DEF COLLECTION_POINT Solid {
  translation 0 -6.0 0.15
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.6 0.1
        roughness 0.4
        metalness 0
        emissiveColor 0.2 0.12 0.02
      }
      geometry Cylinder {
        height 0.3
        radius 0.4
      }
    }
  ]
  name "수거함"
  boundingObject Cylinder {
    height 0.3
    radius 0.4
  }
}

