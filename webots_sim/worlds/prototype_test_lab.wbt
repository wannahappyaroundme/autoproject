#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "../protos/SmartGarbageCollector.proto"

# 40×30 그리드, 1셀=0.5m → 20m×15m
# 좌표: wx=(gx-20)*0.5, wy=(15-gy)*0.5

WorldInfo {
  info ["시제품 테스트장"]
  title "Prototype Test"
  basicTimeStep 32
  contactProperties [
    ContactProperties { material1 "rubber" coulombFriction [1.5] }
    ContactProperties { material1 "rear_tire" coulombFriction [1.5] }
  ]
}
Viewpoint {
  orientation -0.45 0.45 0.77 1.85
  position 0 -18 20
}
TexturedBackground {
}
TexturedBackgroundLight {
}
RectangleArena {
  floorSize 20 15
  floorAppearance PBRAppearance { baseColor 0.82 0.84 0.8 roughness 1 metalness 0 }
  floorTileSize 0.5 0.5
  wallHeight 0.3
  wallThickness 0.08
}

# ── 건물 4동 (소형 5×4셀 = 2.5m×2.0m, 높이 2.0m) ──

# 101동 (grid 4,3~8,6) center: gx=6,gy=4.5 → wx=-7.0, wy=5.25
DEF APT_101 Solid {
  translation -7.0 5.25 1.0
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.6 0.55 0.5 roughness 0.9 metalness 0 }
      geometry Box { size 2.5 2.0 2.0 }
    }
  ]
  name "101동"
  boundingObject Box { size 2.5 2.0 2.0 }
}

