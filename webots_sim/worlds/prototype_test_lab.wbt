# ── 동적 장애물 (웹 동기화, 소형) ──

# 보행자 (1×1셀 = 0.5m, 높이 0.8m — 축소)
DEF OBS_1 Robot {
  translation -4.5 2.5 0.4
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.9 0.7 0.5 roughness 0.8 }
      geometry Cylinder { height 0.8 radius 0.1 }
    }
  ]
  name "obs_1"
  boundingObject Cylinder { height 0.8 radius 0.1 }
  physics Physics { density -1 mass 1 }
  controller "Obstacle_sync_controller"
  controllerArgs ["1"]
  supervisor TRUE
}

