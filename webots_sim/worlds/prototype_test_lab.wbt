# size: 3.5, 3.0, height=0.8
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DEF PLAYGROUND Solid {
  translation 6.0 0.75 0.4
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.85 0.7 0.4
        roughness 1
        metalness 0
      }
      geometry Box {
        size 3.5 3.0 0.8
      }
    }
