#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "../protos/SmartGarbageCollector.proto"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 시제품 테스트장 — 소형 아파트 단지
# 40×30 그리드, 1셀 = 0.5m → 20m × 15m 실제 공간
#
# 좌표 변환 공식:
#   wx = (gx - 20) * 0.5     (그리드 X중심 = 20)
#   wy = (15 - gy) * 0.5     (그리드 Y중심 = 15, Y축 반전)
#   wz = height / 2           (바닥에서 올림)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

WorldInfo {
  info [
    "시제품 테스트장 — 소형 아파트 단지"
    "40x30 그리드 (1셀=0.5m) = 20m x 15m"
    "로봇 2대, 쓰레기통 4개, 건물 4동"
  ]
  title "Prototype Apartment Test"
  basicTimeStep 32
  contactProperties [
    ContactProperties {
      material1 "rubber"
      coulombFriction [1.5]
    }
    ContactProperties {
      material1 "rear_tire"
      coulombFriction [1.5]
    }
  ]
}
Viewpoint {
  orientation -0.45 0.45 0.77 1.85
  position 0 -22 25
}
TexturedBackground {
}
TexturedBackgroundLight {
}

# ── 바닥: 20m × 15m ──
RectangleArena {
  floorSize 20 15
  floorAppearance PBRAppearance {
    baseColor 0.82 0.84 0.8
    roughness 1
    metalness 0
  }
  floorTileSize 0.5 0.5
  wallHeight 0.4
  wallThickness 0.1
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 건물 4동 (아파트)
# grid (x1,y1)~(x2,y2) → center, size
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 101동 (grid: 3,2 ~ 10,8)
# center: gx=6.5, gy=5 → wx=(6.5-20)*0.5=-6.75, wy=(15-5)*0.5=5.0
# size: 8*0.5=4.0, 7*0.5=3.5, height=3.0
DEF APT_101 Solid {
  translation -6.75 5.0 1.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.6 0.55 0.5
        roughness 0.9
        metalness 0
      }
      geometry Box {
        size 4.0 3.5 3.0
      }
    }
  ]
  name "101동"
  boundingObject Box {
    size 4.0 3.5 3.0
  }
}

# 102동 (grid: 15,2 ~ 21,8)
# center: gx=18, gy=5 → wx=-1.0, wy=5.0
# size: 7*0.5=3.5, 7*0.5=3.5, height=3.0
DEF APT_102 Solid {
  translation -1.0 5.0 1.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.55 0.58 0.52
        roughness 0.9
        metalness 0
      }
      geometry Box {
        size 3.5 3.5 3.0
      }
    }
  ]
  name "102동"
  boundingObject Box {
    size 3.5 3.5 3.0
  }
}

# 103동 (grid: 3,15 ~ 10,21)
# center: gx=6.5, gy=18 → wx=-6.75, wy=-1.5
# size: 4.0, 3.5, height=3.0
DEF APT_103 Solid {
  translation -6.75 -1.5 1.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.58 0.52 0.48
        roughness 0.9
        metalness 0
      }
      geometry Box {
        size 4.0 3.5 3.0
      }
    }
  ]
  name "103동"
  boundingObject Box {
    size 4.0 3.5 3.0
  }
}

# 104동 (grid: 15,15 ~ 21,21)
# center: gx=18, gy=18 → wx=-1.0, wy=-1.5
# size: 3.5, 3.5, height=3.0
