# 로봇-A (CS-1에서 시작)
SmartGarbageCollector {
  translation -8.5 -6.0 0.05
  name "Robot_A"
  controller "Prototype_controller"
  bodyColor 0.9 0.2 0.2
}

# 로봇-B (CS-2에서 시작)
