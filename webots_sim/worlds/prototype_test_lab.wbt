  translation -6.75 5.0 1.0
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.62 0.58 0.52 roughness 0.85 }
      geometry Box { size 3.0 2.5 2.0 }
    }
  ]
  name "101동"
  boundingObject Box { size 3.0 2.5 2.0 }
}

