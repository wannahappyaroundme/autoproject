# 40×30, 0.5m/cell = 20m×15m
# wx=(gx-20)*0.5  wy=(15-gy)*0.5

WorldInfo {
  title "Prototype Test"
  basicTimeStep 32
  contactProperties [
    ContactProperties { material1 "rubber" coulombFriction [1.5] }
    ContactProperties { material1 "rear_tire" coulombFriction [1.5] }
  ]
}
Viewpoint {
  orientation -0.45 0.45 0.77 1.85
  position 0 -18 20
}
TexturedBackground {
}
TexturedBackgroundLight {
}
RectangleArena {
  floorSize 20 15
  floorAppearance PBRAppearance { baseColor 0.82 0.84 0.8 roughness 1 metalness 0 }
  floorTileSize 0.5 0.5
  wallHeight 0.3
  wallThickness 0.08
}

# ── 101동 (grid 4,3~9,7) center gx=6.5,gy=5 → wx=-6.75,wy=5.0 size=3.0×2.5 ──
