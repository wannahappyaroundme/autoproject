<?xml version="1.0"?>
<!--
  자율주행 음식물쓰레기통 수거 로봇 URDF
  하드웨어 명세서 기준:
    - 크기: 400 × 300 × 350mm
    - 구동: 전륜 2WD + 후륜 서보 조향
    - 센서: RealSense D435(후면외측) + 웹캠(후면내측) + 초음파×5 + IMU
    - 바퀴: 80mm 고무 타이어

  TF 트리:
    map → odom → base_footprint → base_link
                                    ├── left_wheel_link
                                    ├── right_wheel_link
                                    ├── caster_link
                                    ├── realsense_link (후면 외측)
                                    ├── webcam_link (후면 내측)
                                    ├── imu_link
                                    ├── us_front_left_link
                                    ├── us_front_right_link
                                    ├── us_side_left_link
                                    ├── us_side_right_link
                                    ├── us_rear_link
                                    └── roller_link
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="waste_robot">

  <!-- ==================== 파라미터 ==================== -->
  <xacro:property name="body_length" value="0.40"/>
  <xacro:property name="body_width"  value="0.30"/>
  <xacro:property name="body_height" value="0.20"/>
  <xacro:property name="wheel_radius" value="0.04"/>
  <xacro:property name="wheel_width"  value="0.03"/>
  <xacro:property name="wheel_separation" value="0.32"/>
  <xacro:property name="caster_radius" value="0.025"/>
  <xacro:property name="robot_mass" value="8.0"/>

  <!-- ==================== base_footprint (바닥 투영) ==================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== base_link (본체) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="${robot_mass}"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.15" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ==================== 구동 바퀴 매크로 ==================== -->
  <xacro:macro name="drive_wheel" params="name y_offset">
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${body_length/4} ${y_offset} 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.01" friction="0.1"/>
    </joint>
  </xacro:macro>

  <!-- 좌측 구동 바퀴 -->
  <xacro:drive_wheel name="left_wheel" y_offset="${wheel_separation/2}"/>
  <!-- 우측 구동 바퀴 -->
  <xacro:drive_wheel name="right_wheel" y_offset="${-wheel_separation/2}"/>

  <!-- ==================== 후륜 캐스터 ==================== -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="${-body_length/3} 0 ${-(wheel_radius - caster_radius)}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== 롤러 파지부 (전면) ==================== -->
  <link name="roller_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.25"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 ${pi/2}"/>
      <material name="orange">
        <color rgba="0.8 0.3 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="roller_joint" type="fixed">
    <parent link="base_link"/>
    <child link="roller_link"/>
    <origin xyz="${body_length/2 + 0.02} 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ==================== 센서 매크로 ==================== -->
  <xacro:macro name="sensor_frame" params="name xyz rpy">
    <link name="${name}_link"/>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <!-- 카메라 B: RealSense D435 (후면 외측 — 바깥을 봄) -->
  <xacro:sensor_frame name="realsense"
    xyz="${-body_length/2} 0 ${body_height}"
    rpy="0 0 ${pi}"/>

  <!-- 카메라 A: USB 웹캠 (후면 내측 — 파지부를 봄) -->
  <xacro:sensor_frame name="webcam"
    xyz="${-body_length/2} 0 ${body_height - 0.05}"
    rpy="0 0 0"/>

  <!-- IMU (본체 중앙) -->
  <xacro:sensor_frame name="imu"
    xyz="0 0 ${body_height/2}"
    rpy="0 0 0"/>

  <!-- 초음파 × 5 -->
  <xacro:sensor_frame name="us_front_left"
    xyz="${body_length/2} ${body_width/3} ${body_height/2}"
    rpy="0 0 0.3927"/>
  <xacro:sensor_frame name="us_front_right"
    xyz="${body_length/2} ${-body_width/3} ${body_height/2}"
    rpy="0 0 -0.3927"/>
  <xacro:sensor_frame name="us_side_left"
    xyz="0 ${body_width/2} ${body_height/2}"
    rpy="0 0 ${pi/2}"/>
  <xacro:sensor_frame name="us_side_right"
    xyz="0 ${-body_width/2} ${body_height/2}"
    rpy="0 0 ${-pi/2}"/>
  <xacro:sensor_frame name="us_rear"
    xyz="${-body_length/2} 0 ${body_height/2}"
    rpy="0 0 ${pi}"/>

</robot>
